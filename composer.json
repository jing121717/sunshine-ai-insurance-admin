{
  "name": "demo/sunshine-ai-insurance-admin",
  "description": "Sunshine Insurance AI policy customer service admin based on ThinkPHP6.1",
  "type": "project",
  "require": {
    "php": ">=8.2",
    "topthink/framework": "^6.1",
    "topthink/think-orm": "^2.0",
    "topthink/think-view": "^1.0",
    "phpoffice/phpspreadsheet": "^1.29",
    "predis/predis": "^2.2"
  },
  "autoload": {
    "psr-4": {
      "app\\": "app/"
    },
    "files": [
      "app/helper.php"
    ]
  },
  "scripts": {
    "post-autoload-dump": [
      "@php think service:discover",
      "@php think vendor:publish"
    ]
  }
}

